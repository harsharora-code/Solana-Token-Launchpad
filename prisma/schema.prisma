// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
   id         Int    @id @default(autoincrement())
   username   String
   email      String  @unique
   password   String
   launch     Launch[]
   purchases  Purchase[]
}

model Launch {

  id            Int     @id @default(autoincrement())
  name          String
  Symbol        String
  description   String?
  totalSupply   Int
  pricePerToken Float
  startAt       DateTime
  endAt         DateTime
  maxPerWallet  Int

  creatorId    Int
  creator       User   @relation(fields:[creatorId], references: [id])


  tiers             Tier[]
  whiteListEntry    WhiteListEntry[]
  purchases         Purchase[]

}
model Tier {
  id             Int @id @default(autoincrement())
  minAmount      Int
  maxAmount      Int
  pricePerToken  Float
  launchId       Int  @unique
  launch         Launch @relation(fields: [launchId], references: [id])
}
model WhiteListEntry {

  id       Int    @id @default(autoincrement())
  address  String
  launchId  Int
  launch    Launch @relation(fields:[launchId], references: [id])

}
model Purchase {
  id               Int  @id @default(autoincrement())
  WalletAddress    String
  amount           Int
  totalCost        Float
  txnSignature     String

  userId            Int
  launchId          Int
  user              User @relation(fields: [userId], references: [id])
  launch            Launch @relation(fields: [launchId], references: [id])
}